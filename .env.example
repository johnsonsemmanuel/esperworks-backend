APP_NAME=EsperWorks
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (MySQL on cPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_cpanel_prefix_esperworks
DB_USERNAME=your_cpanel_prefix_dbuser
DB_PASSWORD=your_db_password

# Database Connection Pooling (for high volume usage)
DB_POOL_MIN=5
DB_POOL_MAX=100
DB_POOL_CONNECT_TIMEOUT=10.0
DB_POOL_WAIT_TIMEOUT=30.0
DB_POOL_IDLE_TIMEOUT=60.0
DB_POOL_MAX_LIFETIME=3600.0

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Real-time (Pusher) — get credentials at https://pusher.com/
# Change BROADCAST_CONNECTION=pusher once credentials are added
BROADCAST_CONNECTION=log
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# Paystack (https://dashboard.paystack.com/#/settings/developer)
# Use pk_test_... and sk_test_... for testing; pk_live_... and sk_live_... for production
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PAYMENT_URL=https://api.paystack.co
# Optional contact email (e.g. for support or test notifications)
PAYSTACK_CONTACT_EMAIL=info@example.com

# Email — Option 1: Resend (recommended, 3K/month free)
# Set MAIL_MAILER=resend and add your API key
# MAIL_MAILER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email — Option 2: SMTP (cPanel or Mailgun/SendGrid)
MAIL_MAILER=log
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=465
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="EsperWorks"

SANCTUM_STATEFUL_DOMAINS=yourdomain.com
# Token expiry in minutes (default: 1440 = 24 hours)
SANCTUM_TOKEN_EXPIRATION=1440

# Cloudflare R2 Storage (S3-compatible, 10GB free, zero egress)
# Set FILESYSTEM_DISK=r2 in production to use R2 instead of local disk
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET=esperworks
# CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# CLOUDFLARE_R2_URL=https://pub-<hash>.r2.dev

# Chromium path for Browsershot PDF generation (auto-detected in Docker)
# CHROMIUM_PATH=/usr/bin/chromium

# Security Settings
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Africa's Talking SMS (https://africastalking.com)
# Supports: Ghana (MTN/Vodafone/AirtelTigo), Nigeria, Kenya, Uganda, and 10+ more countries
# Plan quotas: Free=3/mo · Growth=20/mo · Pro=100/mo · Enterprise=unlimited
# AT_USERNAME=sandbox            <- use "sandbox" for testing
# AT_API_KEY=                    <- from AT dashboard → Settings → API Key
# AT_SENDER_ID=EsperWorks        <- optional; requires AT registration in some countries

# Rate Limiting
RATE_LIMITING_ENABLED=true
AUTH_RATE_LIMIT=5,1
API_RATE_LIMIT=60,1
