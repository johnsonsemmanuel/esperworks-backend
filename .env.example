APP_NAME=EsperWorks
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL (for CORS and email links)
FRONTEND_URL=https://yourdomain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database (MySQL on cPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_cpanel_prefix_esperworks
DB_USERNAME=your_cpanel_prefix_dbuser
DB_PASSWORD=your_db_password

# Database Connection Pooling (for high volume usage)
DB_POOL_MIN=5
DB_POOL_MAX=100
DB_POOL_CONNECT_TIMEOUT=10.0
DB_POOL_WAIT_TIMEOUT=30.0
DB_POOL_IDLE_TIMEOUT=60.0
DB_POOL_MAX_LIFETIME=3600.0

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# Paystack (https://dashboard.paystack.com/#/settings/developer)
# Use pk_test_... and sk_test_... for testing; pk_live_... and sk_live_... for production
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PAYMENT_URL=https://api.paystack.co
# Optional contact email (e.g. for support or test notifications)
PAYSTACK_CONTACT_EMAIL=info@example.com

# Email (SMTP - use your cPanel email or service like Mailgun/SendGrid)
MAIL_MAILER=smtp
MAIL_HOST=mail.yourdomain.com
MAIL_PORT=465
MAIL_USERNAME=noreply@yourdomain.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="EsperWorks"

SANCTUM_STATEFUL_DOMAINS=yourdomain.com

# Security Settings
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict
SESSION_PATH=/
SESSION_DOMAIN=null

# CORS Settings
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Rate Limiting
RATE_LIMITING_ENABLED=true
AUTH_RATE_LIMIT=5,1
API_RATE_LIMIT=60,1
