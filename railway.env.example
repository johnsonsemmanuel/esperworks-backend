# ============================================================
#  EsperWorks Backend — Railway Environment Variables
#  Copy these into Railway → Your Backend Service → Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=EsperWorks
APP_ENV=production
APP_DEBUG=false
APP_KEY=                          # Generate: php artisan key:generate --show

# Your Railway backend URL (set AFTER first deploy, e.g. https://esperworks-backend.up.railway.app)
APP_URL=https://YOUR-BACKEND.up.railway.app

# Your Vercel/Railway frontend URL
FRONTEND_URL=https://YOUR-FRONTEND.vercel.app

# ── Database — Link from Railway MySQL plugin ─────────────────
# In Railway: click your backend service → Variables → Add Variable
# Use the "Reference" button to link from your MySQL plugin like this:
#
#   DB_HOST     =  ${{MySQL.MYSQLHOST}}
#   DB_PORT     =  ${{MySQL.MYSQLPORT}}
#   DB_DATABASE =  ${{MySQL.MYSQLDATABASE}}
#   DB_USERNAME =  ${{MySQL.MYSQLUSER}}
#   DB_PASSWORD =  ${{MySQL.MYSQLPASSWORD}}
#
# OR if using the Public Proxy (for external connections):
#   DB_HOST     =  ballast.proxy.rlwy.net   (your proxy hostname)
#   DB_PORT     =  13149                    (your proxy port)
#   DB_DATABASE =  railway
#   DB_USERNAME =  root
#   DB_PASSWORD =  kWRwVlNWKnEfteNXUaPJzkuPFRzIvwjN

DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── Session / Cache ───────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://YOUR-FRONTEND.vercel.app

# Sanctum — must match your frontend domain
SANCTUM_STATEFUL_DOMAINS=YOUR-FRONTEND.vercel.app
SANCTUM_TOKEN_EXPIRATION=1440

# ── Paystack ─────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys
PAYSTACK_PUBLIC_KEY=pk_live_INSERT_YOUR_KEY_HERE
PAYSTACK_SECRET_KEY=sk_live_INSERT_YOUR_KEY_HERE
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_CONTACT_EMAIL=info@esperworks.com

# ── Flutterwave ───────────────────────────────────────────────
# Get from: https://dashboard.flutterwave.com → Settings → API Keys
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_INSERT_YOUR_KEY_HERE
FLUTTERWAVE_SECRET_KEY=FLWSECK_INSERT_YOUR_KEY_HERE
FLUTTERWAVE_WEBHOOK_HASH=your_webhook_hash_from_flutterwave_dashboard
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# ── Email (Resend is recommended — free 3000 emails/month) ────
# Sign up at: https://resend.com → API Keys
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=YOUR_RESEND_API_KEY_HERE
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@esperworks.com
MAIL_FROM_NAME=EsperWorks

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMITING_ENABLED=true
AUTH_RATE_LIMIT=10,1
API_RATE_LIMIT=120,1

# ── Misc ──────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
