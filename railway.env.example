# ============================================================
#  EsperWorks Backend — Railway Environment Variables
#  Copy these into Railway → Backend Service → Variables
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME=EsperWorks
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:c5hVRkPebxLjEM4HcuI1MlwhXdd+UGXWgk6r92skraE=
APP_URL=https://web-production-573b3.up.railway.app
FRONTEND_URL=https://esperworks.vercel.app

# ── Database — Reference from Railway MySQL plugin ───────────
# In Railway click your backend service → Variables → Add Variable
# In the value field click the ${{...}} icon and select from MySQL service
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── Session / Cache ───────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=1440
SESSION_SECURE_COOKIES=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ── Logging ───────────────────────────────────────────────────
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=https://esperworks.vercel.app
SANCTUM_STATEFUL_DOMAINS=esperworks.vercel.app
SANCTUM_TOKEN_EXPIRATION=1440
RATE_LIMITING_ENABLED=true
AUTH_RATE_LIMIT=10,1
API_RATE_LIMIT=120,1

# ── Paystack ─────────────────────────────────────────────────
PAYSTACK_PUBLIC_KEY=pk_live_INSERT_YOUR_KEY_HERE
PAYSTACK_SECRET_KEY=sk_live_INSERT_YOUR_KEY_HERE
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_CONTACT_EMAIL=info@esperworks.com

# ── Flutterwave ───────────────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_INSERT_YOUR_KEY_HERE
FLUTTERWAVE_SECRET_KEY=FLWSECK_INSERT_YOUR_KEY_HERE
FLUTTERWAVE_WEBHOOK_HASH=INSERT_WEBHOOK_HASH_HERE
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# ── Email / SMTP ──────────────────────────────────────────────
# Choose ONE provider below and fill in its credentials.
# Delete or comment out the others.
#
# OPTION 1: Resend (recommended — free 3,000 emails/month)
# Sign up: https://resend.com → API Keys → Create API Key
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=INSERT_RESEND_API_KEY_HERE
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@esperworks.com
MAIL_FROM_NAME=EsperWorks

# OPTION 2: Brevo / Sendinblue (free 300 emails/day)
# Sign up: https://app.brevo.com → SMTP & API → SMTP
# MAIL_MAILER=smtp
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=your_brevo_login_email
# MAIL_PASSWORD=INSERT_BREVO_SMTP_KEY_HERE
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@esperworks.com
# MAIL_FROM_NAME=EsperWorks

# OPTION 3: Gmail (free, limited to 500/day with App Password)
# Go to: Google Account → Security → 2FA → App Passwords
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_gmail@gmail.com
# MAIL_PASSWORD=INSERT_GMAIL_APP_PASSWORD_HERE
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=your_gmail@gmail.com
# MAIL_FROM_NAME=EsperWorks

# OPTION 4: Mailgun (1,000 free/month for 3 months)
# Sign up: https://mailgun.com → Sending → Domain Settings → SMTP credentials
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailgun.org
# MAIL_PORT=587
# MAIL_USERNAME=postmaster@your_mailgun_domain.com
# MAIL_PASSWORD=INSERT_MAILGUN_SMTP_PASSWORD_HERE
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@esperworks.com
# MAIL_FROM_NAME=EsperWorks

# OPTION 5: SendGrid (100 emails/day free)
# Sign up: https://sendgrid.com → Settings → API Keys
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=INSERT_SENDGRID_API_KEY_HERE
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@esperworks.com
# MAIL_FROM_NAME=EsperWorks

# ── Misc ──────────────────────────────────────────────────────
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log
